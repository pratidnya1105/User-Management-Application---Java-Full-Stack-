# ==========================================
# Frontend Ignored Files (React)
# ==========================================
**/node_modules/
**/build/
**/.pnp
**/.pnp.js

# Testing and Coverage reports
**/coverage/

# Log files
*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# ==========================================
# Backend Ignored Files (Spring Boot / Java)
# ==========================================
# Compiled class files
**/*.class

# Log files
**/logs/
*.log

# Package Files
**/*.jar
**/*.war
**/*.nar
**/*.ear
**/*.zip
**/*.tar.gz
**/*.rar

# Maven build directory
**/target/

# ==========================================
# IDE and System Files (Eclipse, VS Code, OS)
# ==========================================
# Eclipse IDE files
**/.metadata/
**/.classpath
**/.project
**/.settings/

# Visual Studio Code files
**/.vscode/
!**/.vscode/extensions.json

# JetBrains (IntelliJ IDEA) files
**/.idea/
**/*.iml
**/*.iws

# Operating system files
**/.DS_Store
**/Thumbs.db

# Environment variables (Sensitive Data)
**/.env
**/.env.local
